# Copy to `.env.local` and fill in dev values to override the production
# OAuth client baked into src/config.ts. `.env.local` is gitignored.

# Client ID of a SEPARATE GitHub OAuth App registered with callback URL
# http://localhost:5173/relai-board/
VITE_GITHUB_CLIENT_ID=

# URL of the dev Cloudflare Worker deployment that holds the matching
# client secret (e.g. https://relai-board-auth-dev.<account>.workers.dev).
VITE_OAUTH_WORKER_URL=
